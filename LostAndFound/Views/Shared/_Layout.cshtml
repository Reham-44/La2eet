@using System
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    string active(string controllerName) => string.Equals(currentController, controllerName, StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - لقيت</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/styles.css" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-laqeet">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Index", "Home")"><i class="fas fa-search-location me-2"></i>ل<span>قيت</span></a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMain">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link @active("Home")" href="@Url.Action("Index", "Home")"><i class="fas fa-home me-1"></i> الرئيسية</a></li>
                    <li class="nav-item"><a class="nav-link @active("Items")" href="@Url.Action("Browse", "Items")"><i class="fas fa-list me-1"></i> تصفح</a></li>

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item"><a class="nav-link @active("Messages")" href="@Url.Action("Index", "Messages")"><i class="fas fa-comments me-1"></i> الرسائل</a></li>
                        <li class="nav-item"><a class="nav-link @active("Claims")" href="@Url.Action("Index", "Claims")"><i class="fas fa-hand-holding me-1"></i> مطالباتي</a></li>

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item"><a class="nav-link @active("Admin")" href="@Url.Action("Index", "Admin")"><i class="fas fa-chart-bar me-1"></i> الإدارة</a></li>
                        }
                    }
                </ul>
                <div class="d-flex align-items-center gap-2">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <a href="@Url.Action("Profile", "Users")" class="btn btn-outline-light btn-sm">
                            <i class="fas fa-user me-1"></i> @User.Identity.Name
                        </a>
                        <a href="@Url.Action("Create", "Items")" class="btn btn-post"><i class="fas fa-plus me-1"></i> أضف بلاغ</a>
                        <form method="post" action="@Url.Action("Logout", "Auth")" class="m-0">
                            <button type="submit" class="btn btn-outline-light btn-sm">
                                <i class="fas fa-sign-out-alt me-1"></i> خروج
                            </button>
                        </form>
                    }
                    else
                    {
                        <a href="@Url.Action("Login", "Auth")" class="btn btn-outline-light btn-sm">
                            <i class="fas fa-sign-in-alt me-1"></i> تسجيل الدخول
                        </a>
                        <a href="@Url.Action("Register", "Auth")" class="btn btn-post">
                            <i class="fas fa-user-plus me-1"></i> إنشاء حساب
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="footer-brand"><i class="fas fa-search-location me-2"></i>ل<span>قيت</span></div>
                    <p class="mt-2">منصة لقيت هي الحل الأول في مصر لاسترداد المفقودات وربط الناس بعضها لإعادة الأغراض لأصحابها.</p>
                    <div class="social-icons mt-3">
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                        <a href="#"><i class="fab fa-whatsapp"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-6">
                    <h5>الصفحات</h5>
                    <a href="@Url.Action("Index", "Home")">الرئيسية</a>
                    <a href="@Url.Action("Browse", "Items")">تصفح البلاغات</a>
                    <a href="@Url.Action("Create", "Items")">أضف بلاغ</a>
                    <a href="@Url.Action("Index", "Messages")">الرسائل</a>
                    <a href="@Url.Action("Index", "Claims")">مطالباتي</a>
                </div>
                <div class="col-lg-2 col-6">
                    <h5>المساعدة</h5>
                    <a href="#">كيف يعمل؟</a>
                    <a href="#">الأسئلة الشائعة</a>
                    <a href="#">سياسة الخصوصية</a>
                    <a href="#">الشروط والأحكام</a>
                </div>
                <div class="col-lg-4">
                    <h5>تواصل معنا</h5>
                    <p><i class="fas fa-envelope me-2 text-warning"></i>support@laqeet.eg</p>
                    <p><i class="fas fa-phone me-2 text-warning"></i>16000</p>
                    <p><i class="fas fa-map-marker-alt me-2 text-warning"></i>القاهرة، مصر</p>
                    <p class="mt-3 small" style="color:rgba(255,255,255,0.5)">الدعم متاح 24/7 على مدار اليوم</p>
                </div>
            </div>
            <hr class="footer-divider" />
            <p class="footer-bottom text-center">© 2025 لقيت. جميع الحقوق محفوظة. صُنع في مصر</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/data.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
