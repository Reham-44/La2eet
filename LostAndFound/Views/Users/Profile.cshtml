@model LostAndFound.Models.ProfileViewModel
@using LostAndFound.Enums
@{
    ViewData["Title"] = "حسابي";
}

<section class="py-5">
    <div class="container">

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-4">
                <div class="d-flex align-items-center gap-3 flex-wrap">
                    <div style="width:70px;height:70px;border-radius:50%;background:#fef3c7;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                        <i class="fas fa-user fa-2x" style="color:#d97706"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mb-1">
                            @Model.FullName
                            @if (Model.IsVerified)
                            {
                                <span class="badge bg-success ms-2"><i class="fas fa-check-circle me-1"></i>موثّق</span>
                            }
                        </h4>
                        <div class="text-muted small">
                            <i class="fas fa-envelope me-1"></i>@Model.Email
                            @if (!string.IsNullOrEmpty(Model.Phone))
                            {
                                <span class="ms-3"><i class="fas fa-phone me-1"></i>@Model.Phone</span>
                            }
                        </div>
                        <div class="text-muted small mt-1">
                            <i class="fas fa-calendar me-1"></i>عضو منذ @Model.CreatedAt.ToString("dd MMM yyyy")
                        </div>
                        <div class="mt-3">
                            <a asp-controller="Users" asp-action="Edit" class="btn btn-outline-warning btn-sm">
                                <i class="fas fa-user-edit me-1"></i>تعديل بياناتي
                            </a>

                          
                        </div>

                    </div>
                </div>

                <hr />

                <div class="row text-center g-3">
                    <div class="col-4">
                        <div class="h4 mb-0 text-primary">@Model.TotalReports</div>
                        <div class="small text-muted">إجمالي البلاغات</div>
                    </div>
                    <div class="col-4">
                        <div class="h4 mb-0 text-success">@Model.ResolvedReports</div>
                        <div class="small text-muted">بلاغات اتحلّت</div>
                    </div>
                    <div class="col-4">
                        <div class="h4 mb-0 text-warning">@Model.TotalClaims</div>
                        <div class="small text-muted">مطالبات قدّمتها</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="section-header d-flex justify-content-between align-items-start flex-wrap gap-2">
            <div>
                <h2>بلاغاتي</h2>
                <div class="section-divider"></div>
                <p>الأغراض اللي بلّغت عنها (مفقودة أو موجودة)</p>
            </div>
        </div>

        @if (!Model.Items.Any())
        {
            <p class="text-muted">لسه معملتش أي بلاغ.</p>
        }
        else
        {
            <div class="row g-3 mb-5">
                @foreach (var item in Model.Items)
                {
                    <div class="col-md-4 col-sm-6">
                        <a asp-controller="Items" asp-action="Details" asp-route-id="@item.ItemId" class="text-decoration-none text-dark">
                            <div class="item-card">
                                <div class="item-card-img-wrap">
                                    @if (!string.IsNullOrEmpty(item.ImageBase64))
                                    {
                                        <img src="@item.ImageBase64" class="item-card-img" alt="@item.Title" loading="lazy" />
                                    }
                                    else
                                    {
                                        <div class="item-card-placeholder">
                                            <i class="fas fa-image"></i>
                                        </div>
                                    }
                                    <span class="badge @(item.Status == ItemType.Lost ? "bg-danger" : "bg-success") position-absolute top-0 end-0 m-2">
                                        @item.Status
                                    </span>
                                </div>
                                <div class="item-card-body">
                                    <div class="item-card-title">
                                        <i class="fas fa-box text-primary me-1"></i>
                                        <span>@item.Title</span>
                                    </div>
                                    <div class="item-card-meta">
                                        <span><i class="fas fa-map-marker-alt"></i>@item.City</span>
                                        <span><i class="fas fa-calendar"></i>@item.CreatedAt.ToString("dd MMM yyyy")</span>
                                    </div>
                                    <div class="mt-2">
                                        @switch (item.ReportStatus)
                                        {
                                            case ReportStatus.Pending:
                                                <span class="badge bg-warning text-dark">قيد المراجعة</span>
                                                break;
                                            case ReportStatus.Approved:
                                                <span class="badge bg-success">مقبول</span>
                                                break;
                                            case ReportStatus.Rejected:
                                                <span class="badge bg-danger">مرفوض</span>
                                                break;
                                        }
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        }

        <div class="section-header d-flex justify-content-between align-items-start flex-wrap gap-2">
            <div>
                <h2>مطالباتي</h2>
                <div class="section-divider"></div>
                <p>المطالبات اللي قدّمتها على بلاغات لأشخاص تانيين</p>
            </div>
        </div>

        @if (!Model.Claims.Any())
        {
            <p class="text-muted">لسه معملتش أي مطالبة.</p>
        }
        else
        {
            <div class="list-group mb-5">
                @foreach (var claim in Model.Claims)
                {
                    <div class="list-group-item d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div>
                            <div class="fw-bold">@claim.Item.Title</div>
                            <div class="small text-muted"><i class="fas fa-calendar me-1"></i>@claim.CreatedAt.ToString("dd MMM yyyy")</div>
                        </div>
                        <span class="badge bg-warning text-dark">@claim.ClaimStatus</span>
                    </div>
                }
            </div>
        }

    </div>
</section>