@model List<LostAndFound.Models.Item>
@{
    ViewData["Title"] = "لقيت – منصة المفقودات والموجودات";
}
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-lg-7">
                <div class="fade-in">
                    <span class="badge bg-warning text-dark mb-3 px-3 py-2"><i class="fas fa-star me-1"></i> منصة رقم 1 في مصر للمفقودات</span>
                    <h1 class="hero-title">لقيت حاجتك؟<br />أو <span>ضيّعت</span> حاجة؟</h1>
                    <p class="hero-sub mt-3 mb-4">
                        منصة <strong>لقيت</strong> بتساعدك تلاقي أغراضك الضايعة أو توصّل اللي لقيته لصاحبه. سهل، سريع، وموثوق.
                    </p>
                    <div class="hero-search-box mb-4">
                        <i class="fas fa-search text-muted" style="margin:0 0.5rem"></i>
                        <input type="text" id="heroSearch" placeholder="ابحث عن محفظة، هاتف، مفاتيح..." />
                        <button onclick="doHeroSearch()"><i class="fas fa-search me-1"></i> ابحث</button>
                    </div>
                    <div class="d-flex gap-3 flex-wrap">
                        <a href="@Url.Action("Create", "Items", new { type = "lost" })" class="btn btn-warning btn-lg"><i class="fas fa-exclamation-circle me-2"></i>بلّغ عن مفقود</a>
                        <a href="@Url.Action("Create", "Items", new { type = "found" })" class="btn btn-outline-light btn-lg"><i class="fas fa-check-circle me-2"></i>أبلّغ عن موجود</a>
                    </div>
                    <div class="hero-stats">
                        <div class="hero-stat"><span class="num" id="statReturned">820+</span><span class="lbl">غرض اتردّ</span></div>
                        <div class="hero-stat"><span class="num" id="statItems">1240+</span><span class="lbl">بلاغ نشيط</span></div>
                        <div class="hero-stat"><span class="num" id="statUsers">3500+</span><span class="lbl">مستخدم</span></div>
                        <div class="hero-stat"><span class="num" id="statCities">18</span><span class="lbl">محافظة</span></div>
                    </div>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="hero-img-wrap" style="min-height:320px;">
                    <img src="https://images.unsplash.com/photo-1578662996442-48f60103fc96?w=400&q=80" class="hero-main-img" alt="لقيت" />
                    <div class="hero-float-card top shadow">
                        <div style="background:#dcfce7;border-radius:50%;width:40px;height:40px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                            <i class="fas fa-check text-success"></i>
                        </div>
                        <div>
                            <div style="font-weight:800;font-size:0.88rem;color:#1a1a2e">محفظة اتردّت!</div>
                            <div style="font-size:0.78rem;color:#6b7280">منذ 5 دقايق</div>
                        </div>
                    </div>
                    <div class="hero-float-card bottom shadow">
                        <div style="background:#fef3c7;border-radius:50%;width:40px;height:40px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                            <i class="fas fa-mobile-alt" style="color:#d97706"></i>
                        </div>
                        <div>
                            <div style="font-weight:800;font-size:0.88rem;color:#1a1a2e">هاتف iPhone تم إيجاده</div>
                            <div style="font-size:0.78rem;color:#6b7280">القاهرة – المعادي</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="section-header d-flex justify-content-between align-items-start flex-wrap gap-2">
            <div>
                <h2>آخر البلاغات</h2>
                <div class="section-divider"></div>
                <p>أحدث المفقودات والموجودات المُضافة على المنصة</p>
            </div>
            <a asp-controller="Items" asp-action="Browse" class="btn btn-outline-primary">عرض الكل <i class="fas fa-arrow-left me-1"></i></a>
        </div>
        <div class="row g-3" id="itemsGrid">

            @foreach (var item in Model.Take<Item>(6))
            {

                <div class="col-md-4 col-sm-6 card-enter">
                    <a asp-controller="Items"
                       asp-action="Details"
                       asp-route-id="@item.ItemId"
                       class="text-decoration-none text-dark">
                        <div class="item-card" center bordernone >
                            <div class="item-card-img-wrap">

                                    @if (!string.IsNullOrEmpty(item.ImageBase64))
                                    {
                                        <img src="@item.ImageBase64"
                                             class="item-card-img"
                                             alt="@item.Title"
                                             loading="lazy" />
                                    }
                                    else
                                    {
                                        <div class="item-card-placeholder">
                                            <i class="fas fa-image"></i>
                                        </div>
                                    }

                                    <span class="badge @(item.Status == ItemType.Lost ? "bg-danger" : "bg-success") position-absolute top-0 end-0 m-2">
                                        @item.Status
                                    </span>

                                </div>
                            <div class="item-card-body">
                                <div class="item-card-title">
                                    <i class="fas fa-box text-primary me-1"></i>
                                    <span>@item.Title</span>
                                </div>
                                <div class="item-card-desc">@item.Description</div>
                                <div class="item-card-meta">
                                    <span><i class="fas fa-map-marker-alt"></i>@item.City</span>
                                    <span><i class="fas fa-calendar"></i>@item.CreatedAt.ToString("dd MMM yyyy")</span>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
        <div class="text-center mt-4">
            <a asp-controller="Items" asp-action="Browse" class="btn btn-primary btn-lg px-5"><i class="fas fa-list me-2"></i>تصفح جميع البلاغات</a>
        </div>
    </div>
</section>

<section class="how-section">
  <div class="container">
    <div class="section-header text-center">
      <h2>إزّاي لقيت بتشتغل؟</h2>
      <div class="section-divider mx-auto"></div>
      <p>3 خطوات بسيطة وتلاقي أو تردّ اللي ضاع</p>
    </div>
    <div class="row g-4 justify-content-center">
      <div class="col-md-4">
        <div class="step-card">
          <div class="step-icon"><i class="fas fa-plus-circle"></i></div>
          <h5>1. ضيف بلاغ</h5>
          <p>سجّل بيانات الغرض الضايع أو اللي لقيته مع صورة وموقع</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="step-card">
          <div class="step-icon" style="background:linear-gradient(135deg,#d97706,#f59e0b)"><i class="fas fa-search"></i></div>
          <h5>2. ابحث وتواصل</h5>
          <p>دور على بلاغات مشابهة وتواصل مع الشخص المعني مباشرة</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="step-card">
          <div class="step-icon" style="background:linear-gradient(135deg,#059669,#10b981)"><i class="fas fa-handshake"></i></div>
          <h5>3. استردّ حاجتك</h5>
          <p>تحقق من الهوية واستردّ غرضك بأمان وسهولة</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="cta-section">
  <div class="container">
    <h2>ضيّعت حاجة أو لقيت حاجة؟</h2>
    <p class="mb-4">انضم لأكثر من 3500 مستخدم بيستعملوا لقيت في مصر كلها</p>
    <div class="d-flex gap-3 justify-content-center flex-wrap">
      <a href="@Url.Action("Create", "Items", new { type = "lost" })" class="btn btn-warning btn-lg"><i class="fas fa-exclamation-circle me-2"></i>بلّغ عن مفقود</a>
      <a href="@Url.Action("Register", "Users")" class="btn btn-outline-light btn-lg"><i class="fas fa-user-plus me-2"></i>انضم مجاناً</a>
    </div>
  </div>
</section>
