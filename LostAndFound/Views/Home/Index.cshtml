      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item"><a class="nav-link active" href="@Url.Action("Index", "Home")"><i class="fas fa-home me-1"></i> الرئيسية</a></li>
        <li class="nav-item"><a class="nav-link" href="@Url.Action("Browse", "Items")"><i class="fas fa-list me-1"></i> تصفح</a></li>
