<!-- ===== HERO ===== -->
<section class="hero-section">
  <div class="container">
    <div class="row align-items-center g-4">
      <div class="col-lg-7">
        <div class="fade-in">
          <span class="badge bg-warning text-dark mb-3 px-3 py-2"><i class="fas fa-star me-1"></i> منصة رقم 1 في مصر للمفقودات</span>
          <h1 class="hero-title">لقيت حاجتك؟<br>أو <span>ضيّعت</span> حاجة؟</h1>
          <p class="hero-sub mt-3 mb-4">
            منصة <strong>لقيت</strong> بتساعدك تلاقي أغراضك الضايعة أو توصّل اللي لقيته لصاحبه. سهل، سريع، وموثوق.
          </p>
          <div class="hero-search-box mb-4">
            <i class="fas fa-search text-muted" style="margin:0 0.5rem"></i>
            <input type="text" id="heroSearch" placeholder="ابحث عن محفظة، هاتف، مفاتيح..." />
            <button onclick="doHeroSearch()"><i class="fas fa-search me-1"></i> ابحث</button>
          </div>
          <div class="d-flex gap-3 flex-wrap">
            <a href="@Url.Action("Create", "Items", new { type = "lost" })" class="btn btn-warning btn-lg"><i class="fas fa-exclamation-circle me-2"></i>بلّغ عن مفقود</a>
            <a href="@Url.Action("Create", "Items", new { type = "found" })" class="btn btn-outline-light btn-lg"><i class="fas fa-check-circle me-2"></i>أبلّغ عن موجود</a>
          </div>
          <div class="hero-stats">
            <div class="hero-stat"><span class="num" id="statReturned">820+</span><span class="lbl">غرض اتردّ</span></div>
            <div class="hero-stat"><span class="num" id="statItems">1240+</span><span class="lbl">بلاغ نشيط</span></div>
            <div class="hero-stat"><span class="num" id="statUsers">3500+</span><span class="lbl">مستخدم</span></div>
            <div class="hero-stat"><span class="num" id="statCities">18</span><span class="lbl">محافظة</span></div>
          </div>
        </div>
      </div>
      <div class="col-lg-5">
        <div class="hero-img-wrap" style="min-height:320px;">
          <img src="https://images.unsplash.com/photo-1578662996442-48f60103fc96?w=400&q=80" class="hero-main-img" alt="لقيت" />
          <div class="hero-float-card top shadow">
            <div style="background:#dcfce7;border-radius:50%;width:40px;height:40px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
              <i class="fas fa-check text-success"></i>
            </div>
            <div>
              <div style="font-weight:800;font-size:0.88rem;color:#1a1a2e">محفظة اتردّت!</div>
              <div style="font-size:0.78rem;color:#6b7280">منذ 5 دقايق</div>
            </div>
          </div>
          <div class="hero-float-card bottom shadow">
            <div style="background:#fef3c7;border-radius:50%;width:40px;height:40px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
              <i class="fas fa-mobile-alt" style="color:#d97706"></i>
            </div>
            <div>
              <div style="font-weight:800;font-size:0.88rem;color:#1a1a2e">هاتف iPhone تم إيجاده</div>
              <div style="font-size:0.78rem;color:#6b7280">القاهرة – المعادي</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

