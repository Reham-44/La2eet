@using System.Globalization
@model LostAndFound.Models.ViewModels.ItemDetailsViewModel
@{
    ViewData["Title"] = "تفاصيل البلاغ";
}

@if (Model == null)
{
    <h2>Item Not Found</h2>
    return;
}
<div style="background:#fff;border-bottom:1px solid var(--border);padding:0.75rem 0;">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item">
                    <a asp-controller="Home"
                       asp-action="Index"
                       class="text-primary">
                        الرئيسية
                    </a>
                </li>
                <li class="breadcrumb-item">
                    <a asp-controller="Items"
                       asp-action="Browse"
                       class="text-primary">
                        تصفح
                    </a>
                </li>

                <li class="breadcrumb-item active" id="breadTitle">تفاصيل البلاغ</li>
            </ol>
        </nav>
    </div>
</div>

<section class="py-4">
    <div class="container" id="detailsContainer">
        <div class="row g-4">
            <div class="col-lg-8">

                @if (!string.IsNullOrEmpty(Model.Item.ImageBase64))
                {
                    <img src="@Model.Item.ImageBase64"
                         class="details-img object-fit-lg-contain mb-3" alt="@Model.Item.Title"
                         loading="lazy" />
                }
                <div class="detail-card">
                    <div class="d-flex justify-content-between  align-items-start flex-wrap gap-2 mb-3">
                        <h3 class="fw-bold mb-0">@Model.Item.Title</h3>

                        <span class="px-3 py-2 badge @(Model.Item.Status == ItemType.Lost ? "bg-danger" : (Model.Item.Status == ItemType.Found) ? "bg-primary bg-opacity-75" : "bg-success")">
                            @Model.Item.Status.GetDisplayName()
                        </span>
                    </div>
                    <p style="color:var(--gray);line-height:1.8">@Model.Item.Description</p>

                    <div class="info-row"><span class="label"><i class="fas fa-map-marker-alt me-1"></i> المدينة</span><span class="value">@Model.Item.City.GetDisplayName()</span></div>
                    <div class="info-row"><span class="label"><i class="fas fa-location-arrow me-1"></i> الموقع</span><span class="value">@Model.Item.Location</span></div>
                    <div class="info-row"><span class="label"><i class="fas fa-calendar me-1"></i> التاريخ</span><span class="value">@Model.Item.LostOrFoundDate.ToString("dd MMMM yyyy", new CultureInfo("ar-EG"))</span></div>
                    <div class="info-row">
                        <span class="label"><i class="fas fa-user me-1"></i> نشر بواسطة</span>
                        <span class="value">
                            <a asp-controller="Users" asp-action="Profile" asp-route-id="@Model.Item.UserId" class="text-decoration-none">
                                @Model.Item.User.FullName
                            </a>
                    </div>                      @if (User.IsInRole("Admin") && Model.Item.User != null)
                      {

                        @if (Model.Item.User != null && Model.Item.User.IsBanned)
                        {
                            <form asp-controller="Admin" asp-action="BanUser" method="post" class="d-inline" onsubmit="return confirm('هل أنت متأكد من فك الحظر عن هذا المستخدم؟');">
                                <input type="hidden" name="userId" value="@Model.Item.UserId" />
                                <button type="submit" class="btn btn-success btn-sm mt-2">
                                    <i class="fas fa-user-check me-1"></i> فك الحظر
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-controller="Admin" asp-action="BanUser" method="post" class="d-inline" onsubmit="return confirm('هل أنت متأكد من حظر هذا المستخدم؟');">
                                <input type="hidden" name="userId" value="@Model.Item.UserId" />
                                <button type="submit" class="btn btn-danger btn-sm mt-2">
                                    <i class="fas fa-ban me-1"></i> حظر
                                </button>
                            </form>
                        }
                       }
                     
                </div>

                <div class="safety-tip mb-3">
                    <i class="fas fa-exclamation-triangle fa-lg"></i>
                    <div>
                        <strong>نصيحة أمان:</strong> دايماً التقِ في مكان عام، وتأكد من هوية الشخص. لو حسيت بأي خطر أو شك، بلّغ الشرطة.
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="detail-card">
                    <h5><i class="fas fa-bolt me-2 text-warning"></i>إجراءات</h5>

                    @{
                        var currentUserId = User.Identity != null && User.Identity.IsAuthenticated
                        ? User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
                        : null;
                        bool isOwner = currentUserId != null && Model.Item.UserId.ToString() == currentUserId;
                        bool alreadyClaimed = ViewBag.AlreadyClaimed ?? false;
                    }
                    @if (Model.Item.IsResolved)
                    {
                        <button class="btn btn-success w-100 mb-2 btn-lg" disabled>
                            <i class="fas fa-check-circle me-2"></i>
                            تم استرجاع الغرض
                        </button>
                    }
                    else if (isOwner)
                    {
                        <div class="alert alert-info small mb-2">
                            <i class="fas fa-info-circle me-1"></i> ده البلاغ بتاعك، هتشوف المطالبات الواردة عليه من صفحة "مطالباتي".
                        </div>
                        <a asp-controller="Claims" asp-action="Index" class="btn btn-primary w-100 mb-2 btn-lg">
                            <i class="fas fa-inbox me-2"></i>عرض المطالبات الواردة
                        </a>
                    }
                    else
                    {
                        if (Model.Item.Status == ItemType.Found)
                        {

                            if (alreadyClaimed)
                            {
                                <button class="btn btn-secondary w-100 mb-2 btn-lg" disabled>
                                    <i class="fas fa-check me-2"></i>
                                    تم إرسال مطالبتك بالفعل
                                </button>

                            }
                            else
                            {
                                <a asp-controller="Claims"
                                asp-action="Create"
                                asp-route-itemId="@Model.Item.ItemId"
                                class="btn btn-primary w-100 mb-2 btn-lg">
                                    <i class="fas fa-hand-holding me-2"></i>
                                    المطالبة بالغرض
                                </a>
                                <div class="safety-tip mb-2">
                                    <i class="fas fa-shield-alt"></i>
                                    <div>المطالبة هتتراجع من قبل صاحب البلاغ عشان يتأكد إنك فعلاً صاحب الغرض.</div>
                                </div>
                            }

                        }
                        else if (Model.Item.Status == ItemType.Lost)
                        {
                            <a asp-controller="Messages"
                            asp-action="Index"
                            asp-route-itemId="@Model.Item.ItemId"
                            asp-route-receiverId="@Model.Item.UserId"
                            class="btn btn-success w-100 mb-2 btn-lg">
                                <i class="fas fa-comments me-2"></i>بدء المحادثة 
                            </a>
                        }
                        <a asp-controller="Items" asp-action="Browse" class="btn btn-outline-secondary w-100"><i class="fas fa-list me-2"></i>عرض مشابهة</a>
                    }
                </div>

                <div class="detail-card">
                    <h5><i class="fas fa-shield-alt me-2 text-success"></i>نصائح السلامة</h5>
                    <ul class="list-unstyled small" style="color:var(--gray)">
                        <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> التقِ في مكان عام ومضاء </li>
                        <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> أخذ معك شخص تاني </li>
                        <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> تحقق من هوية الشخص</li>
                        <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i>بلّغ عن أي سلوك مشبوه </li>
                    </ul>
                </div>
                <a asp-controller="Items"
                   asp-action="Details"
                   asp-route-id="@Model.Item.ItemId"
                   class="text-decoration-none text-dark">                   <div class="detail-card">
                        <h5>
                            <i class="fas fa-layer-group me-2 text-primary text-opacity-75"></i>
                            بلاغات مشابهة
                        </h5>

                        @if (Model.SimilarItems.Any())
                        {
                            @foreach (var item in Model.SimilarItems)
                            {
                                <a asp-controller="Items"
                                   asp-action="Details"
                                   asp-route-id="@item.ItemId"
                                   class="text-decoration-none text-dark">

                                    <div class="d-flex gap-4 mb-3 align-items-center" style="cursor:pointer">

                                        @if (!string.IsNullOrEmpty(item.ImageBase64))
                                        {
                                            <img src="@item.ImageBase64"
                                                 style="width:55px;height:55px;object-fit:cover;border-radius:8px;flex-shrink:0"
                                                 alt="@item.Title" />
                                        }
                                        else
                                        {
                                            <div class="item-card-placeholder"
                                                 style="width:55px;height:55px;border-radius:8px;flex-shrink:0">
                                                <i class="fas fa-image"></i>
                                            </div>
                                        }

                                        <div>
                                            <div class="fw-bold small">@item.Title</div>
                                            <div class="small text-muted">@item.City.GetDisplayName()</div>

                                            <span class="badge @(item.Status == ItemType.Lost ? "bg-danger" :
                                                                                               item.Status == ItemType.Found ? "bg-primary bg-opacity-75" :
                                                                                               "bg-success")">
                                                @item.Status.GetDisplayName()
                                            </span>
                                        </div>

                                    </div>
                                </a>
                            }
                        }
                        else
                        {
                            <div class="text-center text-muted">
                                <i class="fas fa-search fa-2x mb-3 d-block"></i>
                                لا توجد بلاغات مشابهة
                            </div>
                        }
                    </div>


  </a>
                </div>
            </div>
        </div>    
</section>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

