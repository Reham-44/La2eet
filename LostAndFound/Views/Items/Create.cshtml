@using LostAndFound.Enums
@model LostAndFound.Models.ViewModels.ItemViewModel
@{
    ViewData["Title"] = "أضف بلاغ";
}

<div class="post-header">
    <div class="container text-center">
        <h1 class="fw-bold mb-1"><i class="fas fa-plus-circle me-2"></i>أضف بلاغ جديد</h1>
        <p style="color:rgba(255,255,255,0.85)">أبلّغ عن غرض ضاع أو لقيته – ساعد تردّه لصاحبه</p>
    </div>
</div>

<section class="py-4">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">

                <div class="post-card">
                    <form asp-action="Create"
                          asp-controller="Items"
                          method="post"
                          enctype="multipart/form-data"
                          novalidate>
                        <div class="text-danger mb-3"></div>
                        <div class="post-card mb-4 text-center">
                            <h5 class="fw-bold mb-3">نوع البلاغ</h5>
                            <div class="row g-3">

                                <div class="col-6">
                                    <input asp-for="Status"
                                           type="radio"
                                           value="@ItemType.Lost"
                                           id="lost"
                                           class="type-radio"
                                           onchange="toggleVerification()"                        />

                                    <label for="lost" class="type-option p-3 rounded-3 border-2 border w-100">
                                        <i class="fas fa-exclamation-circle fa-2x text-danger mb-2"></i>
                                        <h6 class="fw-bold mb-1">غرض ضاع مني</h6>
                                        <small class="text-muted">بلاغ عن مفقود</small>
                                    </label>
                                </div>

                                <div class="col-6">
                                    <input asp-for="Status"
                                           type="radio"
                                           value="@ItemType.Found"
                                           id="found"
                                           class="type-radio"
                                           onchange="toggleVerification()"                                   />

                                    <label for="found" class="type-option p-3 rounded-3 border-2 border w-100">
                                        <i class="fas fa-check-circle fa-2x text-success mb-2"></i>
                                        <h6 class="fw-bold mb-1">لقيت غرض</h6>
                                        <small class="text-muted">بلاغ عن موجود</small>
                                    </label>
                                </div>

                            </div>
                        </div> 
                        <!-- Basic Info -->
                        <h6 class="fw-bold mb-3 pb-2" style="border-bottom:2px solid var(--primary-light)"><i class="fas fa-info-circle me-2 text-primary"></i>بيانات الغرض</h6>

                        <div class="row g-3 mb-3">
                            <div class="col-12">
                                <label class="form-label" for="itemTitle">اسم الغرض <span class="text-danger">*</span></label>
                                <input asp-for="Title" class="form-control" placeholder="مثال: محفظة جلدية بنية، هاتف iPhone أزرق..." />
                                <span asp-validation-for="Title" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="itemDate">تاريخ الفقدان/الإيجاد <span class="text-danger">*</span></label>
                                <input asp-for="LostOrFoundDate"
                                       id="LostOrFoundDate"
                                       type="date"
                                       class="form-control" />

                                <span asp-validation-for="LostOrFoundDate" class="text-danger"></span>
                                <span id="dateError" class="text-danger"></span>
                            </div>
                            <div class="col-12">
                                <label class="form-label" for="itemDesc">الوصف التفصيلي <span class="text-danger">*</span></label>
                               <textarea asp-for="Description"
                                 class="form-control"
                                           rows="4"></textarea>

                                <span asp-validation-for="Description"
                                      class="text-danger"></span>
                             </div>
                        </div>

                        <!-- Location -->
                        <h6 class="fw-bold mb-3 pb-2" style="border-bottom:2px solid var(--primary-light)"><i class="fas fa-map-marker-alt me-2 text-primary"></i>الموقع</h6>
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label" for="itemCity">المدينة <span class="text-danger">*</span></label>
                                <select asp-for="City"
                                        asp-items="Html.GetEnumSelectList<City>()"
                                        class="form-select">
                                    <option value="">اختر المدينة</option>
                                </select>

                                <span asp-validation-for="City" class="text-danger"></span>

                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="itemLocation">الموقع التفصيلي</label>
                                <input asp-for="Location" class="form-control" placeholder="مثال: محطة مترو، مول، شارع..." />
                            </div>
                        </div>

                        <!-- Image Upload -->
                        <h6 class="fw-bold mb-3 pb-2" style="border-bottom:2px solid var(--primary-light)"><i class="fas fa-camera me-2 text-primary"></i>صورة الغرض</h6>
                        <div class="mb-3">
                            <div class="upload-area" onclick="document.getElementById('imgInput').click()">
                                <i class="fas fa-cloud-upload-alt d-block mb-2"></i>
                                <p class="mb-1 fw-bold">اضغط لرفع صورة</p>
                                <p class="small text-muted">PNG, JPG حتى 5MB</p>
                            </div>
                            <input asp-for="ImageFile"
                                   id="imgInput"
                                   type="file"
                                   style="display:none"
                                   onchange="uploadedImg(this)">
                            <div id="imgPreviewWrap" class="mt-2" style="display:none;">
                                <div class="alert alert-success mb-0">
                                    <i class="fas fa-check-circle me-2"></i>
                                    <strong>تم رفع الصورة:</strong>
                                    <span id="fileName"></span>
                                    <button type="button" class="btn btn-sm btn-outline-danger mt-1" onclick="clearImg()"><i class="fas fa-trash me-1"></i>حذف الصورة</button>
                                </div>
                            </div>
                        </div>


                        <!-- Verification (only for found) -->
                        <div id="verificationSection" onclick="toggleVerification()" style="display:none">
                            <h6 class="fw-bold mb-3 pb-2" style="border-bottom:2px solid var(--primary-light)"><i class="fas fa-shield-alt me-2 text-primary"></i>أسئلة التحقق <span class="badge bg-info text-dark ms-1 small">للموجودات فقط</span></h6>
                            <div class="verification-section mb-3">
                                <p class="small text-muted mb-3"><i class="fas fa-info-circle me-1"></i>ضيف أسئلة تتحقق بيها من هوية صاحب الغرض. اكتب الإجابة الصح بس انت عارفها.</p>
                                <div id="questionsContainer">
                                    <div class="question-item mb-3 row g-2">
                                        <div class="col-md-7">
                                            <label class="form-label small">السؤال <span class="text-danger">*</span></label>
                                            <input asp-for="Questions[0].QuestionText"
                                                   class="form-control"
                                                   placeholder="مثال: كم عدد البطاقات؟" />

                                            <span asp-validation-for="Questions[0].QuestionText"
                                                  class="text-danger"></span>

                                        </div>
                                        <div class="col-md-5">
                                            <label class="form-label small">الإجابة الصحيحة <span class="text-danger">*</span> </label>
                                            <input asp-for="Questions[0].ExpectedAnswerHash"
                                                   class="form-control"
                                                   placeholder="الإجابة" />

                                            <span asp-validation-for="Questions[0].ExpectedAnswerHash"
                                                  class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                                <button type="button" class="btn btn-outline-primary btn-sm" onclick="addQuestion()"><i class="fas fa-plus me-1"></i>أضف سؤال آخر</button>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100"><i class="fas fa-paper-plane me-2"></i>نشر البلاغ</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Success Modal -->
<div class="modal fade" id="successModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-center">
            <div class="modal-body py-4">
                <div style="font-size:4rem" class="mb-3">🎉</div>
                <h4 class="fw-bold text-success">تم نشر البلاغ!</h4>
                <p class="text-muted">تم إضافة بلاغك بنجاح. هيظهر في قائمة البلاغات فوراً.</p>
                <div class="d-flex gap-2 justify-content-center mt-3">
                    <a asp-controller="Items" asp-action="Browse" class="btn btn-primary">تصفح البلاغات</a>
                    <a href="index.html" class="btn btn-outline-secondary">الرئيسية</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="data.js"></script>
<script>

    function uploadedImg(input) {
      if (input.files && input.files.length > 0) {

            document.getElementById("fileName").textContent = input.files[0].name;
            document.getElementById("imgPreviewWrap").style.display = "block";
        }
    }
        document.addEventListener("DOMContentLoaded", function () {
        toggleVerification();
    });
        function clearImg() {
      document.getElementById('imgInput').value = '';
      document.getElementById('imgPreviewWrap').style.display = 'none';
    }


    function toggleVerification() {

    const found = document.getElementById("found").checked;

    document.getElementById("verificationSection").style.display =
        found ? "block" : "none";
    }
    const dateInput = document.getElementById("LostOrFoundDate");
    const dateError = document.getElementById("dateError");

    function validateDate() {
        if (!dateInput.value) {
            dateError.textContent = "";
            return true;
        }

        const selectedDate = new Date(dateInput.value);
        const minDate = new Date("2010-01-01");
        const today = new Date();
        today.setHours(23, 59, 59, 999);

        if (selectedDate < minDate || selectedDate > today) {
            dateError.textContent = "التاريخ يجب أن يكون بين 01/01/2010 واليوم";
            return false;
        }

        dateError.textContent = "";
        return true;
    }

    dateInput.addEventListener("blur", validateDate);

    document.querySelector("form").addEventListener("submit", function (e) {
        if (!validateDate()) {
            e.preventDefault();
        }
    });

     let questionIndex = 1;
    function addQuestion() {

        const c = document.getElementById("questionsContainer");

        const div = document.createElement("div");

        div.className = "question-item mb-3 row g-2";

        div.innerHTML = `
            <div class="col-md-7">
                <label class="form-label small">السؤال<span class="text-danger">*</span></label>
                <input
                    type="text"
                    class="form-control"
                    required 
                    name="questions[${questionIndex}].QuestionText">
            </div>

            <div class="col-md-4">
                <label class="form-label small">الإجابة</label>
                <input
                    type="text"
                    class="form-control"
                    required
                    name="questions[${questionIndex}].ExpectedAnswerHash">
            </div>

            <div class="col-md-1 d-flex align-items-end">
                <button
                    type="button"
                    class="btn btn-outline-danger btn-sm"
                    onclick="this.closest('.question-item').remove()">
                    <i class="fas fa-trash"></i>
                </button>
            </div>
        `;

        c.appendChild(div);

        questionIndex++;
    }

</script>
@section scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
}