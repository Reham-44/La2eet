@using System.Linq
@model LostAndFound.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "نسيت كلمة المرور - لقيت";
}
<section class="auth-section">
  <div class="container">
    <div class="auth-card">
      <div class="text-center mb-4">
        <div style="font-size:2.5rem;color:var(--primary)"><i class="fas fa-key"></i></div>
        <h3 class="mt-2">نسيت كلمة المرور؟</h3>
        <p>اكتب إيميلك وهنبعتلك رابط تقدر تعيد تعيين كلمة المرور بيه</p>
      </div>

      @if (!ViewData.ModelState.IsValid)
      {
        <div class="alert alert-danger">
          <ul class="mb-0">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
              <li>@error.ErrorMessage</li>
            }
          </ul>
        </div>
      }

      <form asp-action="ForgotPassword" asp-controller="Auth" method="post" novalidate>
        <div class="mb-3">
          <label class="form-label" asp-for="Email">البريد الإلكتروني</label>
          <div class="input-group">
            <span class="input-group-text"><i class="fas fa-envelope text-muted"></i></span>
            <input asp-for="Email" class="form-control" placeholder="example@email.com" />
          </div>
          <span asp-validation-for="Email" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100 btn-lg"><i class="fas fa-paper-plane me-2"></i>إرسال رابط إعادة التعيين</button>
      </form>

      <div class="text-center mt-3 small">
        <a asp-controller="Auth" asp-action="Login" class="text-primary fw-bold">رجوع لتسجيل الدخول</a>
      </div>
    </div>
  </div>
</section>
