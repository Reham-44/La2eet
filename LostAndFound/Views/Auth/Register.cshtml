@model LostAndFound.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "إنشاء حساب - لقيت";
}
    <section class="auth-section">
        <div class="container">
            <div class="auth-card">
                <div class="text-center mb-4">
                    <div style="font-size:2.5rem;color:var(--primary)"><i class="fas fa-search-location"></i></div>
                    <h3 class="mt-2">انضم لينا في لقيت</h3>
                    <p>اعمل حساب جديد للمتابعة</p>
                </div>

                <form asp-action="Register" asp-controller="Auth" method="post" novalidate>

                <div class="d-flex gap-2 mb-3">
                    <a asp-action="GoogleLogin"
                       asp-controller="Auth"
                       class="social-btn text-decoration-none d-flex justify-content-center align-items-center">
                        <img src="https://www.svgrepo.com/show/475656/google-color.svg" width="20" class="me-2" />
                        إنشاء حساب باستخدام Google
                    </a>
                </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="FullName">الاسم الكامل</label>
                      
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-user text-muted"></i></span>
                            <input asp-for="FullName" class="form-control" placeholder="اسمك بالكامل" />
                        </div>
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="Email">البريد الإلكتروني</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-envelope text-muted"></i></span>
                            <input asp-for="Email" class="form-control" placeholder="example@email.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="Phone">رقم الهاتف</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-phone text-muted"></i></span>
                            <input asp-for="Phone" class="form-control" placeholder="01xxxxxxxxx" maxlength="11" inputmode="numeric" oninput="this.value=this.value.replace(/[^0-9]/g,'').slice(0,11);" />
                        </div>
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="Password">كلمة المرور</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-lock text-muted"></i></span>
                            <input asp-for="Password" type="password" class="form-control" placeholder="كلمة المرور" id="password" />
                            <button class="btn btn-outline-secondary" type="button" onclick="togglePass('password','eyeIcon1')"><i class="fas fa-eye" id="eyeIcon1"></i></button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="ConfirmPassword">تأكيد كلمة المرور</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-lock text-muted"></i></span>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="أعد كتابة كلمة المرور" id="confirmPassword" />
                            <button class="btn btn-outline-secondary" type="button" onclick="togglePass('confirmPassword','eyeIcon2')"><i class="fas fa-eye" id="eyeIcon2"></i></button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 btn-lg"><i class="fas fa-user-plus me-2"></i>إنشاء الحساب</button>
                </form>

                <div class="text-center mt-3 small">
                    عندك حساب بالفعل؟ <a asp-controller="Auth" asp-action="Login" class="text-primary fw-bold">سجّل دخولك</a>
                </div>
            </div>
        </div>
    </section>

    <script>
        function togglePass(inputId, iconId) {
          const p = document.getElementById(inputId);
          const icon = document.getElementById(iconId);
          if (p.type === 'password') { p.type = 'text'; icon.className = 'fas fa-eye-slash'; }
          else { p.type = 'password'; icon.className = 'fas fa-eye'; }
        }
    </script>

@section scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
}