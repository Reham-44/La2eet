@model LostAndFound.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "تسجيل الدخول - لقيت";
}

    <section class="auth-section">
        <div class="container">
            <div class="auth-card">
                <div class="text-center mb-4">
                    <div style="font-size:2.5rem;color:var(--primary)"><i class="fas fa-search-location"></i></div>
                    <h3 class="mt-2">أهلاً بيك في لقيت</h3>
                    <p>سجّل دخولك للمتابعة</p>
                </div>


            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">
                    @TempData["SuccessMessage"]
                </div>
            }

                @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty]?.Errors.Count > 0)
                {
                    <div class="alert alert-danger">
                        @ViewData.ModelState[string.Empty].Errors.First().ErrorMessage
                    </div>
                }

                <div class="d-flex gap-2 mb-3">
                <a asp-action="GoogleLogin"
                   asp-controller="Auth"
                   class="social-btn text-decoration-none d-flex justify-content-center align-items-center">
                    <img src="https://www.svgrepo.com/show/475656/google-color.svg" width="20" class="me-2" />
                    تسجيل الدخول باستخدام Google
                </a>
            </div>

                <div class="divider-text"><span>أو بالإيميل</span></div>

                <form asp-action="Login" asp-controller="Auth" method="post" novalidate>
                    <div class="mb-3">
                        <label class="form-label" asp-for="Email">البريد الإلكتروني</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-envelope text-muted"></i></span>
                            <input asp-for="Email" class="form-control" placeholder="example@email.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="Password">كلمة المرور</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-lock text-muted"></i></span>
                            <input asp-for="Password" type="password" class="form-control" placeholder="كلمة المرور" id="password" />
                            <button class="btn btn-outline-secondary" type="button" onclick="togglePass()"><i class="fas fa-eye" id="eyeIcon"></i></button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label class="form-check-label small" asp-for="RememberMe">تذكرني</label>
                        </div>
                        <a href="@Url.Action("ForgotPassword", "Auth")" class="small text-primary">نسيت كلمة المرور؟</a>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 btn-lg"><i class="fas fa-sign-in-alt me-2"></i>تسجيل الدخول</button>
                </form>

                <div class="text-center mt-3 small">
                    معندكش حساب؟ <a asp-controller="Auth" asp-action="Register" class="text-primary fw-bold">سجّل دلوقتي</a>
                </div>
            </div>
        </div>
    </section>

    <script>
        function togglePass() {
          const p = document.getElementById('password');
          const icon = document.getElementById('eyeIcon');
          if (p.type === 'password') { p.type = 'text'; icon.className = 'fas fa-eye-slash'; }
          else { p.type = 'password'; icon.className = 'fas fa-eye'; }
        }
    </script>

@section scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
}