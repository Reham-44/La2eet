@using System.Linq
@model LostAndFound.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "إعادة تعيين كلمة المرور - لقيت";
}
<section class="auth-section">
  <div class="container">
    <div class="auth-card">
      <div class="text-center mb-4">
        <div style="font-size:2.5rem;color:var(--primary)"><i class="fas fa-lock"></i></div>
        <h3 class="mt-2">إعادة تعيين كلمة المرور</h3>
        <p>اكتب كلمة مرور جديدة لحسابك</p>
      </div>

      @if (!ViewData.ModelState.IsValid)
      {
        <div class="alert alert-danger">
          <ul class="mb-0">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
              <li>@error.ErrorMessage</li>
            }
          </ul>
        </div>
      }

      <form asp-action="ResetPassword" asp-controller="Auth" method="post" novalidate>
        <input type="hidden" asp-for="Email" />
        <input type="hidden" asp-for="Token" />

        <div class="mb-3">
          <label class="form-label" asp-for="NewPassword">كلمة المرور الجديدة</label>
          <div class="input-group">
            <span class="input-group-text"><i class="fas fa-lock text-muted"></i></span>
            <input asp-for="NewPassword" type="password" class="form-control" placeholder="كلمة المرور الجديدة" />
          </div>
          <span asp-validation-for="NewPassword" class="text-danger small"></span>
        </div>

        <div class="mb-3">
          <label class="form-label" asp-for="ConfirmPassword">تأكيد كلمة المرور</label>
          <div class="input-group">
            <span class="input-group-text"><i class="fas fa-lock text-muted"></i></span>
            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="أعد كتابة كلمة المرور" />
          </div>
          <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100 btn-lg"><i class="fas fa-check me-2"></i>تغيير كلمة المرور</button>
      </form>
    </div>
  </div>
</section>

