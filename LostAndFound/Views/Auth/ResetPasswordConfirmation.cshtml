@{
    ViewData["Title"] = "تم التغيير - لقيت";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"]</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="~/css/styles.css" />
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-laqeet">
  <div class="container">
    <a class="navbar-brand" asp-controller="Home" asp-action="Index"><i class="fas fa-search-location me-2"></i>ل<span>قيت</span></a>
  </div>
</nav>

<section class="auth-section">
  <div class="container">
    <div class="auth-card text-center">
      <div style="font-size:2.5rem;color:var(--bs-success)"><i class="fas fa-check-circle"></i></div>
      <h3 class="mt-2 mb-3">تم تغيير كلمة المرور بنجاح</h3>
      <p class="text-muted">تقدر دلوقتي تسجل دخولك بكلمة المرور الجديدة</p>
      <a asp-controller="Auth" asp-action="Login" class="btn btn-primary w-100 mt-2">تسجيل الدخول</a>
    </div>
  </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
