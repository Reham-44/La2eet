@{
    ViewData["Title"] = "تقديم مطالبة";
    Layout = null;
    var item = ViewBag.Item as LostAndFound.Models.Item;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/styles.css" />
</head>
<body>
    <div class="container py-5" style="max-width:600px;">
        <h2 class="mb-4"><i class="fas fa-hand-holding me-2"></i>مطالبة بالغرض: @item?.Title</h2>
        <p class="text-muted mb-4">جاوب على أسئلة التحقق دي عشان تثبت إنك فعلاً صاحب الغرض.</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <form method="post" asp-controller="Claims" asp-action="Create">
            <input type="hidden" name="itemId" value="@item?.ItemId" />

            @if (item?.VerificationQuestions != null && item.VerificationQuestions.Any())
            {
                int i = 1;
                foreach (var q in item.VerificationQuestions)
                {
                    <div class="mb-3">
                        <label class="form-label fw-bold">سؤال @i: @q.QuestionText</label>
                        <input type="text" name="answer_@q.QId" class="form-control" placeholder="اكتب إجابتك..." required />
                    </div>
                    i++;
                }
            }
            else
            {
                <div class="mb-3">
                    <label class="form-label fw-bold">إجابة سؤال التحقق (لإثبات إنك صاحب الغرض)</label>
                    <textarea name="verificationAnswer" class="form-control" rows="3" required></textarea>
                </div>
            }

            <button type="submit" class="btn btn-primary w-100">إرسال المطالبة</button>
            <a asp-controller="Items" asp-action="Details" asp-route-id="@item?.ItemId" class="btn btn-outline-secondary w-100 mt-2">إلغاء</a>
        </form>
    </div>
</body>
</html>
