@{
    ViewData["Title"] = "تقديم مطالبة";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    var item = ViewBag.Item as LostAndFound.Models.Item;
}
<div class="browse-header">
    <div class="container text-center">
        <h1 class="fw-bold">
            <i class="fas fa-hand-holding me-2"></i>
            تقديم مطالبة
        </h1>

        <p class="text-white-50 mb-0">
            أجب عن أسئلة التحقق لإثبات ملكيتك للغرض.
        </p>
    </div>
</div>

<div class="container py-5" style="max-width:900px;">

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger rounded-4 mb-4">
            @ViewBag.Error
        </div>
    }

    <form method="post"
          asp-controller="Claims"
          asp-action="Create">

        <input type="hidden"
               name="itemId"
               value="@item?.ItemId" />

        <div class="card border-0 shadow-sm rounded-4">

            <div class="card-body p-4">

                <h4 class="fw-bold mb-4">
                    <i class="fas fa-circle-question text-primary me-2"></i>
                    أسئلة التحقق
                </h4>

                @if (item?.VerificationQuestions != null &&
                                item.VerificationQuestions.Any())
                {
                    int i = 1;

                    foreach (var q in item.VerificationQuestions)
                    {
                        <div class="question-card mb-4">

                            <label class="fw-bold mb-3 d-block">

                                <span class="question-number">
                                    @i
                                </span>

                                @q.QuestionText

                            </label>

                            <input type="text"
                                   class="form-control form-control-lg"
                                   name="answer_@q.QId"
                                   placeholder="اكتب إجابتك بوضوح"
                                   required />

                        </div>

                        i++;
                    }
                }

            </div>

        </div>


        <div class="d-grid gap-3 mt-4">

            <button type="submit"
                    class="btn btn-primary btn-lg rounded-pill">

                <i class="fas fa-paper-plane me-2"></i>

                إرسال المطالبة

            </button>

            <a asp-controller="Items"
               asp-action="Details"
               asp-route-id="@item?.ItemId"
               class="btn btn-outline-secondary rounded-pill">

                <i class="fas fa-arrow-right me-2"></i>

                إلغاء

            </a>

        </div>

    </form>

</div>
