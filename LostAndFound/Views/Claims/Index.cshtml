@using LostAndFound.Models.ViewModels
@model ClaimsIndexViewModel
@{
    ViewData["Title"] = "المطالبات - لقيت";
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/styles.css" />
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-laqeet">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index"><i class="fas fa-search-location me-2"></i>ل<span>قيت</span></a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMain">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index"><i class="fas fa-home me-1"></i> الرئيسية</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Browse" asp-action="Index"><i class="fas fa-list me-1"></i> تصفح</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Messages" asp-action="Index"><i class="fas fa-comments me-1"></i> الرسائل</a></li>
                    <li class="nav-item"><a class="nav-link active" asp-controller="Claims" asp-action="Index"><i class="fas fa-hand-holding me-1"></i> مطالباتي</a></li>
                </ul>
                <div class="d-flex align-items-center gap-2">
                    <a asp-controller="Profile" asp-action="Index" class="btn btn-outline-light btn-sm"><i class="fas fa-user me-1"></i> حسابي</a>
                    <a asp-controller="Post" asp-action="Index" class="btn btn-post"><i class="fas fa-plus me-1"></i> أضف بلاغ</a>
                </div>
            </div>
        </div>
    </nav>

    <div class="browse-header">
        <div class="container">
            <h1><i class="fas fa-hand-holding me-2"></i>المطالبات</h1>
            <p class="mb-0 mt-1" style="color:rgba(255,255,255,0.8)">تابع مطالباتك والمطالبات الواردة على بلاغاتك</p>
        </div>
    </div>

    <section class="py-4">
        <div class="container">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }

            <ul class="nav nav-tabs mb-4" id="claimsTabs">
                <li class="nav-item"><a class="nav-link active" href="#myClaims" data-bs-toggle="tab"><i class="fas fa-paper-plane me-1"></i>مطالباتي</a></li>
                <li class="nav-item"><a class="nav-link" href="#incoming" data-bs-toggle="tab"><i class="fas fa-inbox me-1"></i>مطالبات واردة</a></li>
            </ul>

            <div class="tab-content">
                <!-- My Claims -->
                <div class="tab-pane fade show active" id="myClaims">
                    @if (!Model.MyClaims.Any())
                    {
                        <div class="text-center text-muted py-5">
                            <i class="fas fa-hand-holding fa-2x mb-3 d-block"></i>
                            لا توجد مطالبات حاليًا
                        </div>
                    }
                    else
                    {
                        foreach (var c in Model.MyClaims)
                        {
                            <div class="claim-row">
                                @if (!string.IsNullOrEmpty(c.Item?.ImageBase64))
                                {
                                    <img src="data:image/jpeg;base64,@c.Item.ImageBase64" class="claim-img" />
                                }
                                <div style="flex:1">
                                    <div class="fw-bold">@c.Item?.Title</div>
                                    <div class="small text-muted">طلبت في @c.CreatedAt.ToString("yyyy-MM-dd")</div>
                                </div>
                                @{
                                    var (label, css) = c.ClaimStatus switch
                                    {
                                        LostAndFound.Enums.ClaimStatus.Approved => ("مقبول", "success"),
                                        LostAndFound.Enums.ClaimStatus.Rejected => ("مرفوض", "danger"),
                                        _ => ("قيد المراجعة", "warning text-dark")
                                    };
                                }
                                <span class="badge bg-@css">@label</span>
                                <a asp-controller="Items" asp-action="Details" asp-route-id="@c.ItemId" class="btn btn-sm btn-outline-primary">عرض</a>
                                @if (c.ClaimStatus == ClaimStatus.Approved && !c.Item.IsResolved)
                                {
                                        <a asp-controller="Messages"
       asp-action="Index"
       asp-route-itemId="@c.ItemId"
                                       asp-route-receiverId="@c.Item.UserId"
       class="btn btn-primary">
        فتح المحادثة
    </a>
                                }
                                else
                                {
                                 <span class="badge bg-primary">رجعت لصاحبها</span>

                                }
                            </div>
                        }
                    }
                </div>

                <!-- Incoming Claims -->
                <div class="tab-pane fade" id="incoming">
                    @if (!Model.IncomingClaims.Any())
                    {
                        <div class="text-center text-muted py-5">
                            <i class="fas fa-inbox fa-2x mb-3 d-block"></i>
                            لا توجد مطالبات واردة حاليًا
                        </div>
                    }
                    else
                    {
                        foreach (var c in Model.IncomingClaims)
                        {
                            <div class="claim-row">
                                @if (!string.IsNullOrEmpty(c.Item?.ImageBase64))
                                {
                                    <img src="data:image/jpeg;base64,@c.Item.ImageBase64" class="claim-img" />
                                }
                                <div style="flex:1">
                                    <div class="fw-bold">@c.User?.FullName طالب بـ "@c.Item?.Title"</div>
                                    <div class="small text-muted"><i class="fas fa-phone me-1"></i>@c.User?.Phone | @c.CreatedAt.ToString("yyyy-MM-dd")</div>
                                </div>

                                @if (c.ClaimStatus == LostAndFound.Enums.ClaimStatus.Pending)
                                {
                                    <span class="badge bg-warning text-dark">جديد</span>
                                    <div class="d-flex gap-1">
                                        <form method="post" asp-action="Approve" asp-route-id="@c.ClaimId">
                                            <button type="submit" class="btn btn-sm btn-success"><i class="fas fa-check me-1"></i>قبول</button>
                                        </form>
                                        <form method="post" asp-action="Reject" asp-route-id="@c.ClaimId">
                                            <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-times me-1"></i>رفض</button>
                                        </form>
                                    </div>
                                }
                                else if (c.ClaimStatus == ClaimStatus.Approved)
                                {
                                    <span class="badge bg-success">تم القبول</span>
                                    if (!c.Item.IsResolved)
                                    {
                                        <a asp-controller="Messages"
                                        asp-action="Index"
                                        asp-route-itemId="@c.ItemId"
                                        asp-route-receiverId="@c.UserId"
                                        class="btn btn-primary">
                                            فتح المحادثة
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary">رجعت لصاحبها</span>

                                    }
                                }
                                else
                                {
                                    <span class="badge bg-danger">مرفوض</span>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </section>

    <footer class="footer mt-4">
        <div class="container">
            <div class="row g-3">
                <div class="col-lg-6"><div class="footer-brand"><i class="fas fa-search-location me-2"></i>ل<span>قيت</span></div><p class="mt-2">منصة لقيت هي الحل الأول في مصر لاسترداد المفقودات.</p></div>
                <div class="col-lg-3 col-6"><h5>روابط</h5><a asp-controller="Home" asp-action="Index">الرئيسية</a><a asp-controller="Browse" asp-action="Index">التصفح</a></div>
                <div class="col-lg-3 col-6"><h5>تواصل</h5><p><i class="fas fa-phone me-2 text-warning"></i>16000</p></div>
            </div>
            <hr class="footer-divider" />
            <p class="footer-bottom text-center">© 2025 لقيت. جميع الحقوق محفوظة.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
