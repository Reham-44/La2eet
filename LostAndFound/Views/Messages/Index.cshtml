@using LostAndFound.Models.ViewModels
<!-- Messages View - Placeholder -->
@model ChatPageVM
@{
    ViewData["Title"] = "الرسائل";
}
    <div class="browse-header">
        <div class="container">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                <div>
                    <h1><i class="fas fa-comments me-2"></i>الرسائل</h1>
                    <p class="mb-0 mt-1" style="color:rgba(255,255,255,0.8)">محادثات المطالبات التي اجتازت أسئلة التحقق</p>
                </div>
                <a href="claims.html" class="btn btn-warning"><i class="fas fa-hand-holding me-1"></i> مطالباتي</a>
            </div>
        </div>
    </div>

    <section class="py-4">
        <div class="container">
            <div class="msg-container">
                <aside class="msg-sidebar" id="conversationList">
                    <div class="msg-sidebar-header">
                        <i class="fas fa-shield-alt me-2 text-primary"></i>محادثات موثقة
                    </div>
                </aside>

                <main class="msg-main">
                <div class="msg-header" id="chatHeader">

                    <div class="chat-user">

                        <div class="chat-avatar">
                            <i class="fas fa-user"></i>
                        </div>

                        <div class="chat-info">
                            <div class="chat-name"></div>
                            <div class="chat-item"></div>
                        </div>

                    </div>

                    <div class="chat-actions">
                    </div>

                </div>
                    <div class="msg-body" id="messageBody"></div>
                    <form class="msg-footer" id="messageForm">
                  <input class="msg-input"
                           id="messageInput"
                           placeholder="اكتب رسالتك..."
                           autocomplete="off" />

                    <button type="button"
                            class="btn btn-outline-success"
                            id="btnReturned">
                        <i class="fas fa-check-circle"></i>
                        رجعت لصاحبها
                    </button>

                    <button class="btn btn-primary send-btn" type="submit">
                        <i class="fas fa-paper-plane"></i>
                    </button>

                    </form>
                </main>
            </div>
        </div>
        </section>

<script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>

<script>
    const currentUserId = @Model.CurrentUserId;

    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/chatHub")
        .build();

    connection
        .start()
        .catch(err => console.error(err));

    let conversations = @Html.Raw(Json.Serialize(Model.Chats));

    let activeConversation =
        conversations.length > 0
            ? conversations[0]
            : null;


    connection.on("ReceiveMessage", function (senderId, receiverId, itemId, message) {

        if (!activeConversation)
            return;

        if (
            itemId !== activeConversation.itemId ||
            (
                senderId !== activeConversation.otherUserId &&
                receiverId !== activeConversation.otherUserId
            )
        ) {
            return;
        }

        const conv = conversations.find(c =>
            c.itemId === itemId &&
            c.otherUserId ===
            (senderId === currentUserId ? receiverId : senderId)
        );

        if (!conv)
            return;

        conv.messages.push({
            senderId: senderId,
            content: message,
            sentAt: new Date().toISOString(),
            sentTime: "الآن"
        });

        if (
            activeConversation &&
            activeConversation.itemId === conv.itemId &&
            activeConversation.otherUserId === conv.otherUserId
        ) {
            renderMessages();
        }

    });


    connection.on("ChatClosed", function (itemId) {

        const conv = conversations.find(c => c.itemId === itemId);

        if (!conv)
            return;

        conv.isClosed = true;

        if (
            activeConversation &&
            activeConversation.itemId === conv.itemId &&
            activeConversation.otherUserId === conv.otherUserId
        ) {
            renderMessages();
        }

    });
    
                  function renderConversations() {

        const list = document.getElementById("conversationList");

        list.innerHTML =
            `
            <div class="msg-sidebar-header">
                <i class="fas fa-shield-alt me-2 text-primary"></i>
                محادثات موثقة
            </div>
            ` +
            conversations.map((c, index) => `

            <div class="conv-item ${activeConversation === conversations[index] ? "active" : ""}"
                 onclick="selectConversation(${index})">

                <i class="conv-avatar fas fa-image"></i>

                <div style="min-width:0">

                    <div class="conv-name">
                        ${escapeHtml(c.otherUserName)}
                    </div>

                    <div class="conv-preview">
                        ${escapeHtml(c.lastMessage ?? "")}
                    </div>

                </div>

                <span class="conv-time">
                    ${escapeHtml(c.lastMessageTimeText)}
                </span>

            </div>

        `).join("");

    }



    function renderMessages() {

        if (!activeConversation)
            return;

        let html = "";
        let lastDate = "";

        activeConversation.messages.forEach(m => {

            const label = getDateLabel(m.sentAt);

            if (label !== lastDate) {

                html += `
                    <div class="date-divider">
                        ${label}
                    </div>
                `;

                lastDate = label;
            }

            html += `
                <div class="bubble ${m.senderId === currentUserId ? "me" : "other"}">

                    ${escapeHtml(m.content)}

                    <div class="bubble-time">
                        ${escapeHtml(m.sentTime)}
                    </div>

                </div>
            `;

        });

        document.getElementById("messageBody").innerHTML = html;


        if (activeConversation.isClosed) {

            document.getElementById("messageBody").innerHTML += `
                <div class="text-center mt-4">

                    <div class="alert alert-success">

                        <i class="fas fa-check-circle me-2"></i>

                        تم إنهاء هذه المحادثة بعد استلام المفقود.

                    </div>

                </div>
            `;
        }

        document.getElementById("conversationList").style.display = "block";
        document.getElementById("messageForm").style.display = "flex";
        document.getElementById("chatHeader").style.display = "flex";

        document.getElementById("chatHeader").innerHTML = `
            <div class="chat-user">

                <div class="chat-avatar">
                    <i class="fas fa-user"></i>
                </div>

                <div class="chat-info">

                    <div class="chat-name">
                        ${escapeHtml(activeConversation.otherUserName)}
                    </div>

                    <div class="chat-item">
                        ${escapeHtml(activeConversation.itemTitle)}
                    </div>

                </div>

            </div>

            <div class="chat-actions">

                <span class="verified-badge">
                    <i class="fas fa-check-circle"></i>
                    مطالبة موثقة
                </span>

            </div>
        `;

        const input = document.getElementById("messageInput");
        const sendBtn = document.querySelector(".send-btn");
        const returnBtn = document.getElementById("btnReturned");

        returnBtn.style.display =
            activeConversation.canMarkReturned
                ? "inline-flex"
                : "none";

        if (activeConversation.isClosed) {

            input.disabled = true;
            sendBtn.disabled = true;

            returnBtn.style.display = "none";

            input.placeholder = "تم إنهاء المحادثة";

        } else {

            input.disabled = false;
            sendBtn.disabled = false;
            returnBtn.disabled = false;

            input.placeholder = "اكتب رسالتك...";
        }

        const body = document.getElementById("messageBody");
        body.scrollTop = body.scrollHeight;
    }

        function renderEmptyState() {

        document.getElementById("messageBody").innerHTML = `
            <div class="d-flex flex-column justify-content-center align-items-center h-100 text-center">

                <i class="fas fa-comments fa-5x text-secondary mb-4"></i>

                <h4>لا توجد محادثات حالياً</h4>

                <p class="text-muted">
                    يمكنك بدء محادثة من صفحة المطالبات المقبولة
                </p>

            </div>
        `;

        document.getElementById("conversationList").style.display = "none";
        document.getElementById("messageForm").style.display = "none";
        document.getElementById("chatHeader").style.display = "none";
    }


    function getDateLabel(date) {

        const d = new Date(date);

        const today = new Date();

        const yesterday = new Date();
        yesterday.setDate(today.getDate() - 1);

        if (d.toDateString() === today.toDateString())
            return "اليوم";

        if (d.toDateString() === yesterday.toDateString())
            return "أمس";

        return d.toLocaleDateString("ar-EG");
    }


    function selectConversation(index) {

        activeConversation = conversations[index];

        renderConversations();
        renderMessages();
    }



    document
        .getElementById("btnReturned")
        .addEventListener("click", function () {

            if (!activeConversation)
                return;

            if (!confirm("هل تم تسليم الشيء لصاحبه؟"))
                return;

            fetch("/Messages/MarkAsReturned", {

                method: "POST",

                headers: {
                    "Content-Type": "application/x-www-form-urlencoded"
                },

                body: "itemId=" + activeConversation.itemId

            })
            .then(response => response.json())
            .then(data => {

                if (!data.success)
                    return;

                alert("تم إنهاء المحادثة بنجاح");

                activeConversation.isClosed = true;

                renderMessages();

            })
            .catch(err => console.error(err));

        });

        

    document
        .getElementById("messageForm")
        .addEventListener("submit", function (e) {

            e.preventDefault();

            if (!activeConversation)
                return;

            const input = document.getElementById("messageInput");
            const text = input.value.trim();

            if (!text)
                return;

            connection.invoke(
                "SendMessage",
                currentUserId,
                activeConversation.otherUserId,
                activeConversation.itemId,
                text
            )
            .then(() => {
                input.value = "";
            })
            .catch(err => console.error(err));

        });


    document.addEventListener("DOMContentLoaded", function () {

        if (conversations.length === 0) {

            renderEmptyState();
            return;
        }

        renderConversations();
        renderMessages();

    });


            </script>

